# Docker Compose project
COMPOSE_PROJECT_NAME=rememora

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8152

# API
API_PORT=8152
API_HOST=0.0.0.0

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rememora

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Optional: override DSN directly instead of POSTGRES_* split config
# DATABASE_URL=postgresql://postgres:postgres@db:5432/rememora
